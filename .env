
# --- Tamano del canvas de video ---
# Dimensiones en pixeles del renderer Three.js.
# El canvas se centrara en el browser con el espacio sobrante en negro.
#
# Ejemplos comunes:
#   1280 x 720  -> HD (16:9)
#   1920 x 1080 -> Full HD (16:9)
#    854 x 480  -> SD (16:9)

VITE_CANVAS_WIDTH=854
VITE_CANVAS_HEIGHT=480

# --- Efecto Parallax (ojos flotantes) ---
# Escala minima y maxima de los ojos.
# El modelo eye.glb necesita escala ~35 para ser del tamano de un ojo en la cara.
# Referencia: 30=pequeno | 200=mediano | 600=grande | 900=enorme
# Distribucion exponencial: la mayoria seran pequenos, pocos seran enormes.

VITE_EYE_SCALE_MIN=30
VITE_EYE_SCALE_MAX=300

# Numero de ojos flotantes (recomendado: 25-50)
VITE_EYE_COUNT=35

# Intensidad del efecto parallax (cuanto se mueven los ojos al mover la cara)
# 1.0 = suave | 3.0 = notable | 6.0 = agresivo | 10.0 = extremo
VITE_PARALLAX_INTENSITY=4.0

# --- Efecto Snap (ojo del tercer ojo en la frente) ---
# Escala del ojo 3D que aparece entre tus ojos al hacer snap.
# 35 = tamano por defecto | 20 = mas pequeno | 60 = mas grande

VITE_SNAP_EYE_SCALE=70
VITE_SNAP_CHAKRA_SCALE=0.7
